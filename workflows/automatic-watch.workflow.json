[
  {
    "id": "vRssAutoIA062026",
    "name": "Automatic Watch - AI Inbox",
    "description": "Reads configured RSS feeds, ranks recent items, summarizes selected sources, and adds them to the AI Inbox.",
    "active": true,
    "isArchived": false,
    "nodes": [
      {
        "id": "11a0bff3-6171-4af0-948d-27f106bab601",
        "name": "Every day at 6:10",
        "type": "n8n-nodes-base.scheduleTrigger",
        "typeVersion": 1.2,
        "position": [
