              }
            ]
          }
        }
      },
      {
        "id": "92fe8a24-764a-4429-8046-370444a3ef02",
        "name": "AI Inbox - existing URLs",
        "type": "n8n-nodes-base.notion",
        "typeVersion": 2.2,
        "position": [
          400,
          240
        ],
        "parameters": {
          "resource": "databasePage",
          "operation": "getAll",
          "databaseId": {
            "__rl": true,
            "value": "={{ $env.NOTION_INBOX_DATABASE_ID }}",
            "mode": "id",
            "cachedResultName": "AI Inbox"
          },
          "returnAll": true,
          "options": {}
        },
        "credentials": {
          "notionApi": {
            "id": "__NOTION_CREDENTIAL_ID__",
            "name": "Notion account"
          }
        },
        "alwaysOutputData": true,
        "executeOnce": true,
        "onError": "continueRegularOutput"
      },
      {
        "id": "1a998ac5-b58b-4ec9-8538-b2f819aeb503",
        "name": "RSS sources",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          640,
          240
        ],
        "parameters": {
          "mode": "runOnceForAllItems",
          "jsCode": "const feeds = ($env.WATCH_RSS_FEEDS || '').split(',').map(s => s.trim()).filter(Boolean);\nif (!feeds.length) throw new Error('WATCH_RSS_FEEDS is empty');\nconst notionItems = $('AI Inbox - existing URLs').all();\nif (notionItems.some(i => i.json && i.json.error)) throw new Error('Unable to read existing Inbox URLs from Notion');\nreturn feeds.map(feed_url => ({ json: { feed_url } }));"
        }
      },
      {
        "id": "6457c4fa-dbc7-445d-ad23-c2820e055704",
        "name": "Read RSS feeds",
        "type": "n8n-nodes-base.rssFeedRead",
        "typeVersion": 1.2,
        "position": [
          880,
          240
        ],
        "parameters": {
          "url": "={{ $json.feed_url }}",
          "options": {
            "customFields": "author,contentSnippet"
          }
        },
        "onError": "continueRegularOutput"
      },
      {
        "id": "61e92f4b-cdd2-4fa4-9ef2-d0d4d9b7c905",
        "name": "Filter and rank",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1120,
          240
        ],
        "parameters": {
          "mode": "runOnceForAllItems",
          "jsCode": "const MAX_ITEMS = Number($env.WATCH_MAX_ITEMS || 4);\nconst MAX_PER_HOST = Number($env.WATCH_MAX_PER_HOST || 2);\nconst MAX_AGE_HOURS = Number($env.WATCH_MAX_AGE_HOURS || 72);\nconst now = Date.now();\n\nconst textOf = (v) => {\n  if (v == null) return '';\n  if (Array.isArray(v)) return v.map(textOf).filter(Boolean).join(' ');\n  if (typeof v === 'object') return v.plain_text || v.name || v.value || v.url || '';\n  return String(v);\n};\nconst normalizeUrl = (raw) => {\n  let value = textOf(raw).trim().split('#')[0];\n  if (!/^https?:\\/\\//i.test(value)) return '';\n  value = value.replace(/([?&])(utm_[^=&]+|ref|source)=[^&]*/gi, '$1').replace(/[?&]+$/, '');\n  return value.replace(/\\/$/, '');\n};\nconst hostOf = (url) => ((url.match(/^https?:\\/\\/([^/]+)/i) || [])[1] || '').replace(/^www\\./, '');\nconst existing = new Set();\nfor (const item of $('AI Inbox - existing URLs').all()) {\n  const j = item.json || {}; const p = j.properties || {}; const src = { ...p, ...j };\n  for (const key of ['property_url', 'URL', 'url']) { const value = normalizeUrl(textOf(src[key])); if (value) existing.add(value); }\n}\nconst keywords = ($env.WATCH_KEYWORDS || '').split(',').map(s => s.trim().toLowerCase()).filter(Boolean);\nif (!keywords.length) throw new Error('WATCH_KEYWORDS is empty');\nconst candidates = [];\nfor (const item of $input.all()) {\n  const j = item.json || {};\n  const url = normalizeUrl(j.link || j.guid || '');\n  const title = textOf(j.title).trim();\n  if (!url || !title || existing.has(url) || j.error) continue;\n  const publishedRaw = j.isoDate || j.pubDate || j.published || j.updated;\n  const publishedAt = publishedRaw ? new Date(publishedRaw).getTime() : NaN;\n  if (!Number.isFinite(publishedAt) || publishedAt > now + 3600000 || now - publishedAt > MAX_AGE_HOURS * 3600000) continue;\n  const excerpt = textOf(j.contentSnippet || j.content || j.summary || j.description).replace(/<[^>]+>/g, ' ').replace(/\\s+/g, ' ').trim().slice(0, 1400);\n  const haystack = (title + ' ' + excerpt).toLowerCase();\n  let score = 0; const reasons = [];\n  for (const term of keywords) {\n    if (haystack.includes(term)) { score += term.includes(' ') ? 3 : 2; reasons.push(term); }\n  }\n  if (score < 2) continue;\n  candidates.push({ url, title, excerpt, published_at: new Date(publishedAt).toISOString(), score, reasons: [...new Set(reasons)].slice(0, 4), host: hostOf(url) });\n}\nconst counts = {}; const selected = [];\nfor (const c of candidates.sort((a, b) => b.score - a.score || new Date(b.published_at) - new Date(a.published_at))) {\n  if ((counts[c.host] || 0) >= MAX_PER_HOST) continue;\n  counts[c.host] = (counts[c.host] || 0) + 1; selected.push(c);\n  if (selected.length >= MAX_ITEMS) break;\n}\nreturn selected.map(c => ({ json: c }));"
        }
      },
      {
        "id": "e5d98a13-823d-483a-9eed-ab02f18d1106",
        "name": "Memo Bridge - summarize",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [
