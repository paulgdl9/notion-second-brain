                "value": "2022-06-28"
              }
            ]
          },
          "sendBody": true,
          "specifyBody": "json",
          "jsonBody": "={{ JSON.stringify($json.body) }}",
          "options": {
            "timeout": 15000
          }
        },
        "id": "a74a2334-c8c9-43c3-92d0-5b98f31837e4",
        "name": "Update completion date",
        "type": "n8n-nodes-base.httpRequest",
