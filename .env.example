# Copy to <repo>/.env and fill in the values. Never commit the real .env file.

MEMO_TOKEN=replace-with-random-hex
CAPTURE_TOKEN=replace-with-random-hex
MEMO_PORT=8088
# URL of the bridge as seen from inside the n8n container. host.docker.internal
# resolves to the host thanks to extra_hosts in docker-compose.yml.
MEMO_BRIDGE_URL=http://host.docker.internal:8088
# Optional: absolute paths to the Claude / Codex CLIs. Leave empty to auto-discover on PATH.
CLAUDE_BIN=
CODEX_BIN=
# Optional: where the watchdog writes heartbeat state. Leave empty for <repo>/runtime.
MONITOR_STATE_DIR=
# Optional: bind address for the local bridge. Default 0.0.0.0 so the n8n container can reach
# it via host.docker.internal. Access is always gated by MEMO_TOKEN; on a shared LAN you may
# also restrict this and/or firewall MEMO_PORT.
MEMO_BIND=0.0.0.0
# Optional: set to 0 to stop sending captured URLs to r.jina.ai for content extraction
# (falls back to a built-in HTML parser). Tweets still resolve through api.fxtwitter.com.
MEMO_USE_JINA=1
# Optional: LLM engine time budgets in seconds. Claude then Codex share one budget, kept under
# the n8n HTTP node timeouts so the Codex fallback can actually run. Defaults: 210 / 120 / 75.
# BRIEF_BUDGET=210
# SUMMARIZE_BUDGET=120
# CODEX_RESERVE_SECONDS=75

TIMEZONE=UTC

# --- How you reach n8n -------------------------------------------------------
# install.sh asks this and fills the vars below; you can also edit by hand.
# ACCESS_MODE just lets install.sh remember your choice: lan | vpn | tunnel
ACCESS_MODE=
# COMPOSE_PROFILES=tunnel starts the cloudflared container. Empty for lan/vpn.
COMPOSE_PROFILES=
# Where n8n is published on the host: 127.0.0.1 = local only (tunnel mode),
# 0.0.0.0 = reachable on your LAN/VPN (lan/vpn). You can also pin a single IP.
N8N_BIND=127.0.0.1
# http for lan/vpn, https for a public tunnel.
N8N_PROTOCOL=https
# The host/URL you use to reach n8n. tunnel: your public domain. lan/vpn: IP:5678.
N8N_HOST=n8n.example.com
N8N_PUBLIC_URL=https://n8n.example.com
N8N_CAPTURE_URL=https://n8n.example.com/webhook/capture

NOTION_INBOX_DATABASE_ID=
NOTION_DAILY_BRIEF_PAGE_ID=
NOTION_NOTES_PAGE_ID=
NOTION_CONTEXT_PAGE_ID=
NOTION_OBJECTIVES_DATABASE_ID=
NOTION_TASKS_DATABASE_ID=
# Optional: a Readwise or other library database. Leave empty to skip it.
NOTION_LIBRARY_DATABASE_ID=
N8N_NOTION_CREDENTIAL_ID=

MEMO_AREAS=Work,Projects,Finance,Health,Learning,Personal,Knowledge
WATCH_RSS_FEEDS=https://example.com/feed.xml
WATCH_KEYWORDS="product,growth,security,automation"
WATCH_MAX_ITEMS=4
WATCH_MAX_PER_HOST=2
WATCH_MAX_AGE_HOURS=72

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
BRIEF_EXPECTED_BY=08:15
# Weekly Review output language and generation model.
WEEKLY_LANGUAGE=French
WEEKLY_MODEL=claude-sonnet-4-6

CLOUDFLARED_TOKEN=replace-with-cloudflare-tunnel-token
